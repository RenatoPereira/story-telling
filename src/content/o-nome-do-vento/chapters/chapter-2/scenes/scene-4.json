{
  "id": "scene-4",
  "title": "Reshi e Bast",
  "backgroundImage": "/assets/backgrounds/noite.svg",
  "audio": {
    "enabled": true,
    "defaultVoice": "alloy",
    "ambientTrack": "/assets/audio/cap1-reshi-bast.wav"
